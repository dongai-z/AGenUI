{
  "description": "Tests aspect-ratio conflicting with explicit width and height. Both dimensions specified alongside aspect-ratio creates an over-constrained layout.",
  "surfaceId": "stability-aspect-conflict",
  "messages": [
    {
      "version": "v0.9",
      "createSurface": {
        "surfaceId": "stability-aspect-conflict",
        "catalogId": "https://a2ui.org/specification/v0_9/basic_catalog.json"
      }
    },
    {
      "version": "v0.9",
      "updateComponents": {
        "surfaceId": "stability-aspect-conflict",
        "components": [
          {"id": "root", "component": "Column", "children": ["a1", "a2", "a3", "a4"], "styles": {"width": "100%", "padding": "8px", "gap": "8px"}},
          {"id": "a1", "component": "Image", "properties": {"url": "https://example.com/img.png", "width": 200, "height": 100}, "styles": {"aspect-ratio": "2", "width": "200px", "height": "200px"}},
          {"id": "a2", "component": "Column", "children": ["a2c"], "styles": {"aspect-ratio": "0.5", "width": "100%", "height": "100px"}},
          {"id": "a2c", "component": "Text", "text": "In 0.5 aspect container", "styles": {"width": "100%"}},
          {"id": "a3", "component": "Image", "properties": {"url": "https://example.com/img2.png", "width": 50, "height": 50}, "styles": {"aspect-ratio": "3", "width": "100px", "max-height": "20px"}},
          {"id": "a4", "component": "Column", "children": ["a4c"], "styles": {"aspect-ratio": "1", "min-width": "200px", "max-width": "100px", "height": "150px"}},
          {"id": "a4c", "component": "Text", "text": "Triple conflict: aspect + min/max + height", "styles": {"width": "100%"}}
        ]
      }
    }
  ],
  "stability_meta": {
    "category": "extreme_components",
    "stress_level": "extreme",
    "expected_behavior": "no_crash"
  }
}
