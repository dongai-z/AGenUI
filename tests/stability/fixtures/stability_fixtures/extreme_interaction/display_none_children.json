      {"id":"vis1","component":"Text","text":"Visible 1","styles":{"width":"100%"}},
      {"id":"hid1","component":"Column","children":["hid1a","hid1b"],"styles":{"display":"none"}},
      {"id":"hid1a","component":"Text","text":"Hidden child A"},
