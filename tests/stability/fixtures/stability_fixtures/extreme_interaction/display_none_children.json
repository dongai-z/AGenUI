      {"id":"hid1b","component":"Image","properties":{"url":"https://example.com/shown.png","width":200,"height":200},"styles":{"width":"100%","height":"100px"}},
      {"id":"vis2","component":"Text","text":"Still visible","styles":{"width":"100%"}},
      {"id":"hid2","component":"Row","children":["hid2a"],"styles":{"width":"100%"}},
      {"id":"hid2a","component":"Text","text":"Row content now visible"},
      {"id":"vis3","component":"Text","text":"Still visible 3","styles":{"width":"100%"}},
      {"id":"hid3","component":"Chart","properties":{"chartType":"line","data":{"labels":["A","B"],"datasets":[{"label":"Data","data":[10,20]}]}},"styles":{"width":"100%","height":"200px"}}
    ]}}
