      {"id":"vis3","component":"Text","text":"Visible 3","styles":{"width":"100%"}},
      {"id":"hid3","component":"Chart","properties":{"chartType":"bar","data":{"labels":["X"],"datasets":[{"label":"Y","data":[100]}]}},"styles":{"display":"none","width":"100%","height":"300px"}}
    ]}},
    {"version":"v0.9","updateComponents":{"surfaceId":"stability-display-none","components":[
      {"id":"root","component":"Column","children":["vis1","hid1","vis2","hid2","vis3","hid3"],"styles":{"width":"100%","padding":"8px","gap":"8px"}},
