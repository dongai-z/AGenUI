{
  "description": "SKILL-05: pluralize localization function test, verifies branch (zero/one/two/other) selection logic via Text.text FunctionCall binding",
  "surfaceId": "test-surf-fc-05",
  "messages": [
    {
      "version": "v0.9",
      "createSurface": {
