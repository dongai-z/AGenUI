    "componentIds": ["root", "text-05a", "text-05b", "text-05c", "text-05d", "text-05e", "text-05f"],
    "textContent": [
      { "componentId": "text-05a", "contains": "No items",   "note": "SKILL-05-a: count=0 uses zero branch" },
      { "componentId": "text-05b", "contains": "1 item",     "note": "SKILL-05-b: count=1 uses one branch" },
      { "componentId": "text-05c", "contains": "2 items",    "note": "SKILL-05-c: count=2 uses two branch" },
      { "componentId": "text-05d", "contains": "items",      "note": "SKILL-05-d: count=5 no matching branch, falls back to other" },
      { "componentId": "text-05e", "contains": "items",      "note": "SKILL-05-e: count=0 no zero branch, falls back to other" },
      { "componentId": "text-05f", "contains": "two items",  "note": "SKILL-05-f: float 1.6 rounded to 2, uses two branch" }
    ]
