            },
            "variant": "body"
          },
          {
            "id": "text-05b",
            "component": "Text",
            "text": {
              "call": "pluralize",
              "args": { "value": 1, "one": "1 item", "other": "items" },
              "returnType": "string"
            },
            "variant": "body"
          },
          {
            "id": "text-05c",
            "component": "Text",
            "text": {
              "call": "pluralize",
              "args": { "value": 2, "two": "2 items", "other": "items" },
              "returnType": "string"
            },
            "variant": "body"
          },
          {
            "id": "text-05d",
            "component": "Text",
            "text": {
              "call": "pluralize",
              "args": { "value": 5, "one": "item", "other": "items" },
              "returnType": "string"
            },
            "variant": "body"
          },
          {
            "id": "text-05e",
            "component": "Text",
            "text": {
              "call": "pluralize",
              "args": { "value": 0, "one": "item", "other": "items" },
              "returnType": "string"
            },
            "variant": "body"
          },
          {
            "id": "text-05f",
            "component": "Text",
            "text": {
              "call": "pluralize",
              "args": { "value": 1.6, "one": "one item", "two": "two items", "other": "many items" },
              "returnType": "string"
            },
            "variant": "body"
          }
        ]
      }
    }
  ],
  "expect": {
