{
  "description": "SKILL-01: formatDate date formatting function test, verifies rendering result via Text.text FunctionCall binding",
  "surfaceId": "test-surf-fc-01",
  "messages": [
    {
      "version": "v0.9",
      "createSurface": {
        "surfaceId": "test-surf-fc-01",
        "catalogId": "https://a2ui.org/specification/v0_9/basic_catalog.json"
      }
    },
    {
      "version": "v0.9",
      "updateComponents": {
        "surfaceId": "test-surf-fc-01",
        "components": [
          {
            "id": "root",
